# Copy to .env and fill in real values.  .env is gitignored.

PORT=3000

# Redis — locally use the docker-compose service name; on Render this is
# auto-injected from the Key Value resource via render.yaml.
REDIS_URL=redis://redis:6379

# RabbitMQ / LavinMQ — get this from your CloudAMQP instance dashboard
# (https://customer.cloudamqp.com -> your instance -> "AMQP details" -> URL)
# Example: amqps://user:pass@host.lmq.cloudamqp.com/vhost
RABBITMQ_URL=amqps://USER:PASSWORD@HOST.lmq.cloudamqp.com/VHOST

# Optional: only needed if you want to script CloudAMQP from the CLI
CLOUDAMQP_API_KEY=
